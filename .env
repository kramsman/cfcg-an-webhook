####
# In Cloud run load_dotenv() is not run and these variables are not set.
# Checking if they exists tells the program if it is running locall or in Run.
# In Cloud Run, set these as environment variables in the console or via gcloud.
####

# true = send welcome emails to new signups
SEND_RECIPIENT_EMAILS=true
# true = send admin alert emails on errors/warnings (bad osdi type, zip not found, etc.); usually false locally
SEND_NOTIFICATION_EMAILS=true

# TEST_MODE=true redirects welcome emails to TEST_RECIPIENT_EMAILS instead of real volunteers.
# Set to false only when ready to go live.
TEST_MODE=true

# Email settings
FROM_EMAIL=centerforcommonground.tech@gmail.com
FROM_NAME=Center for Common Ground Team
LOGO_URL=https://storage.googleapis.com/cfcg-an-webhook-storage-trim-sunlight-489423-h3/CFCG_logo.png

# Required when TEST_MODE=true. Welcome emails go here instead of real volunteers.
# Subject line will be prefixed with [TEST].
TEST_RECIPIENT_EMAILS=kramsman@yahoo.com

# Comma-separated list of emails that receive admin alert emails (errors, warnings).
# Required when SEND_NOTIFICATION_EMAILS=true.
ADMIN_ALERT_EMAILS=kramsman@yahoo.com

# Comma-separated list of emails that receive a copy of every incoming payload (for monitoring).
# Leave empty to disable.
PAYLOAD_OBSERVER_EMAILS=kramsman@yahoo.com

# Comma-separated osdi types whose payload notification emails are suppressed.
# Use short type names (without osdi: prefix): attendance, outreach, submission, etc.
EXCLUDED_PAYLOAD_OSDI=attendance,outreach

# Idempotency / duplicate checks (turn on for production)
CHECK_IDEMPOTENCY=false
# true = look up AN record before emailing to skip people who already got a welcome email
CHECK_ALREADY_EMAILED=false
# true = look up the Google Sheet to skip anyone whose email is already logged there
CHECK_SHEET_FOR_EMAIL=false
# true = email even if person already existed in AN before this signup (only applies when CHECK_ALREADY_EMAILED=true)
SEND_TO_EXISTING_EMAILS=false

# Set to true to write the region group_key back to Action Network after emailing
UPDATE_GROUP_KEY=false

# Emails added to every outgoing welcome email as a backup to only Org receiving email. Format: email:name,email:name
# Leave empty to add no one.
ALWAYS_CC_LIST=
ALWAYS_BCC_LIST=

# Log raw incoming webhook payloads (contains personal info — turn off when stable)
LOG_PAYLOADS=true

# Log outgoing email details (contains personal info — turn off when stable)
LOG_EMAILS=true

# Google Sheet append — set APPEND_TO_SHEET=true to enable.
APPEND_TO_SHEET=true

# Production sheet (used when TEST_MODE=false).
# Sheet ID is the long alphanumeric string in the sheet URL between /d/ and /edit.
GOOGLE_SHEET_ID=15vrphBaWAGPgsF4PlzligEwF-J7IShQVMMqidxvjsp0  # jsp0 is production
SHEET_TAB=AN-2026-RAW-DATA

# Test sheet (used when TEST_MODE=true and APPEND_TO_SHEET=true).
# Required when APPEND_TO_SHEET=true and TEST_MODE=true.
TEST_SHEET_ID=1TSQ4OEyAETpYV3FPfqiFgDvpH6lN3kscMTOfTkvYI58  # YI58 is Copy of sheet for testing
TEST_SHEET_TAB=AN-2026-RAW-DATA

# true = group records sharing the same AN UUID and process together — prevents duplicate emails when someone donates AND submits a form at once
REMOVE_MULTI_IDENTIFIERS=true
# seconds to wait before processing a buffered group; 600 locally, 7200 in prod
TRANSACTION_WINDOW_SECONDS=5

# Required — get this from the GCP Console
# CLOUD_PROJECT_ID=354456242651
CLOUD_PROJECT_ID=trim-sunlight-489423-h3

# Path to local zip_dict.json for development.
# If set via load_dotenv(), loads from this file but if left empty (as in Cloud Run), loads from Google Cloud Service
# (GCS) instead.  If blank then looks in work directory.
# Example: ZIP_DICT_PATH=/Users/yourname/path/to/cfcg-an-webhook/zip_dict.json
ZIP_DICT_PATH=

# GCS bucket where zip_dict.json is stored
#GCS_BUCKET=cfcg-an-webhook-storage-cfcg-an-webhook
GCS_BUCKET=cfcg-an-webhook-storage-trim-sunlight-489423-h3

# To protect key values the .env file is NOT committed to git (it's in .gitignore).

# SendGrid API key — stored in GCP Secret Manager, NOT here (it's a real secret).
# The app fetches it automatically at startup using CLOUD_PROJECT_ID above.
# To find it: GCP Console → Secret Manager → secret named "SENDGRID_API_KEY"
# To add/update it: gcloud secrets versions add SENDGRID_API_KEY --data-file=-
#   When running locally, gcloud auth application-default login gives your machine the same
#   access to GCP Secret Manager as Cloud Run does. So get_secret("SENDGRID_API_KEY") works
#   locally and sends real emails — TEST_MODE=true is your safety net to prevent emailing
#   real volunteers during local development.
