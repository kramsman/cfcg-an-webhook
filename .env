####
# In Cloud run load_dotenv() is not run and these variables are not set.
# Checking if they exists tells the program if it is running locall or in Run.
# In Cloud Run, set these as environment variables in the console or via gcloud.
####

# Set to false to disable sending emails (useful for testing)
SEND_RECIPIENT_EMAILS=true
SEND_NOTIFICATION_EMAILS=false

# Email settings
#FROM_EMAIL=tech@centerforcommonground.org
FROM_EMAIL=centerforcommonground.tech@gmail.com
FROM_NAME=Center for Common Ground Team
LOGO_URL=https://storage.googleapis.com/cfcg-an-webhook-storage-trim-sunlight-489423-h3/CFCG_logo.png

# Comma-separated list of emails that receive admin notification emails (errors, warnings).
NOTIFICATION_EMAIL_LIST=rovmailtester@gmail.com, kramsman@yahoo.com

# Comma-separated list of emails that receive a copy of every incoming payload (for monitoring).
# Leave empty to disable.
PAYLOAD_NOTIFICATION=kramsman@yahoo.com

# Comma-separated list of emails allowed to receive mail during testing.
# Leave empty to send to everyone (production mode).
ALLOWED_RECIPIENT_EMAILS=centerforcommonground.tech@gmail.com,rovmailtester@gmail.com, kramsman@yahoo.com

# Idempotency / duplicate checks (turn on for production)
CHECK_IDEMPOTENCY=false
CHECK_ALREADY_EMAILED=true
# Send email even when person already exists in AN system (requires CHECK_ALREADY_EMAILED=true)
SEND_TO_EXISTING_EMAILS=true

# Set to true to write the region group_key back to Action Network after emailing
UPDATE_GROUP_KEY=false

# Emails added to every outgoing welcome email as a backup to only Org receiving email. Format: email:name,email:name
# Leave empty to add no one.
ALWAYS_CC_LIST=
ALWAYS_BCC_LIST=

# Log raw incoming webhook payloads (contains personal info — turn off when stable)
LOG_PAYLOADS=true

# Log outgoing email details (contains personal info — turn off when stable)
LOG_EMAILS=true

# Required — get this from the GCP Console
# CLOUD_PROJECT_ID=354456242651
CLOUD_PROJECT_ID=trim-sunlight-489423-h3

# Path to local zip_dict.json for development.
# If set via load_dotenv(), loads from this file but if left empty (as in Cloud Run), loads from Google Cloud Service
# (GCS) instead.  If blank then looks in work directory.
# Example: ZIP_DICT_PATH=/Users/yourname/path/to/cfcg-an-webhook/zip_dict.json
ZIP_DICT_PATH=

# GCS bucket where zip_dict.json is stored
#GCS_BUCKET=cfcg-an-webhook-storage-cfcg-an-webhook
GCS_BUCKET=cfcg-an-webhook-storage-trim-sunlight-489423-h3

# To protect key values the .env file is NOT committed to git (it's in .gitignore).

# SendGrid API key — stored in GCP Secret Manager, NOT here (it's a real secret).
# The app fetches it automatically at startup using CLOUD_PROJECT_ID above.
# To find it: GCP Console → Secret Manager → secret named "SENDGRID_API_KEY"
# To add/update it: gcloud secrets versions add SENDGRID_API_KEY --data-file=-
#  Emails can still be sent running locally even though the sendgrid secret is not in .env and only in secrets on gcs,
# because:
#   When you run locally, you're logged in via gcloud auth application-default login. That gives your local machine
#   the same ability to reach GCP Secret Manager as Cloud Run does. So
#   get_secret("SENDGRID_API_KEY") works locally just fine, fetches the real key, and sends real emails.
#   That's why ALLOWED_RECIPIENT_EMAILS exists — it's your safety net to prevent local testing from emailing real signups. As long as that's set in your .env, only those addresses will
#   receive mail.
